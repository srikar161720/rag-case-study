# ─────────────────────────────────────────────────────────────────────────────
# Customs Analytics Agent — frontend .env contract
#
# Copy to .env.local (scripts/setup.sh does this and syncs BACKEND_API_KEY
# from backend/.env automatically). Read by Next.js at build/runtime.
#
# Variable visibility:
#   NEXT_PUBLIC_*  — inlined into the browser bundle (safe for non-secrets).
#   Anything else  — server-side only; never sent to the browser.
#
# In production, Vercel project env vars override .env.local (Fork 39).
# ─────────────────────────────────────────────────────────────────────────────

# Backend origin used by the Next.js server-side /api/chat proxy (Fork 29).
# In Vercel preview/prod this is the Fly.io URL: https://customs-agent-backend.fly.dev
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080

# Server-side-only auth key forwarded as X-API-Key by the proxy route.
# scripts/setup.sh syncs this from backend/.env so dev parity is automatic.
# NOT prefixed with NEXT_PUBLIC_ — never exposed to the browser.
BACKEND_API_KEY=
