# ─────────────────────────────────────────────────────────────────────────────
# Customs Analytics Agent — backend .env contract
#
# Copy to .env (scripts/setup.sh does this and auto-generates BACKEND_API_KEY),
# then fill in the required provider keys. Loaded by
# customs_agent.config.Settings (Pydantic-settings, case-insensitive).
#
# Required (Settings raises ValidationError if missing or empty):
#   ANTHROPIC_API_KEY  BACKEND_API_KEY  ALLOWED_ORIGINS
#
# OPENAI_API_KEY is build-time only — needed locally for `make build-index`
# and for the Q9 eval judge. Once the index is baked into the Docker image
# (chore/dockerfile-fly branch via BuildKit --mount=type=secret), the runtime
# container does not read it.
# ─────────────────────────────────────────────────────────────────────────────

# === LLM (Forks 5, 13, 26 + G1) =============================================
# Anthropic — main agent model (runtime, required).
ANTHROPIC_API_KEY=

# OpenAI — RAG embeddings (build-time, Fork 13) and Q9 eval judge (Fork 8).
# Required to run `make build-index` and the eval suite. Not read at runtime.
OPENAI_API_KEY=

# Model pins (defaults are good; override only when intentionally swapping).
LLM_MODEL=claude-sonnet-4-6
LLM_JUDGE_MODEL=gpt-4o-mini
LLM_EMBEDDING_MODEL=text-embedding-3-small
LLM_TEMPERATURE=0.0
LLM_SEED=42

# === Auth (Fork 48) =========================================================
# Static API key for the X-API-Key header. scripts/setup.sh auto-generates
# this via `openssl rand -base64 32` when copying this file to .env.
BACKEND_API_KEY=

# === CORS (Fork 38) =========================================================
# Comma-separated allowlist. Entries wrapped in ^...$ are treated as regex.
# Local-only default below; production sets this in Fly secrets.
ALLOWED_ORIGINS=http://localhost:3000

# === Observability (Forks 10, 54) ===========================================
# Langfuse Cloud — leave blank to disable tracing locally.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://us.cloud.langfuse.com

# "development" → structlog ConsoleRenderer (human-readable, colored).
# "production"  → structlog JSONRenderer  (machine-parseable; set in fly.toml).
ENVIRONMENT=development

# === Agent tuning (Fork 23) =================================================
AGENT_MAX_ITERATIONS=5
AGENT_MAX_INPUT_TOKENS_PER_TURN=50000
AGENT_MAX_OUTPUT_TOKENS_PER_TURN=8000

# === Rate limit (Fork 47) ===================================================
RATELIMIT_ENABLED=true
RATELIMIT_CHAT_PER_MINUTE=20
RATELIMIT_STARTER_PROMPTS_PER_MINUTE=60

# === Safety (Fork 49) =======================================================
SAFETY_MAX_USER_MESSAGE_CHARS=2000
SAFETY_OUTPUT_SANITY_CHECK_ENABLED=true
