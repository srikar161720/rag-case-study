# ─────────────────────────────────────────────────────────────────────────────
# Environment / secrets
# ─────────────────────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.production
.env.development
# Keep example contracts in version control
!.env.example
!backend/.env.example
!frontend/.env.example

# ─────────────────────────────────────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────────────────────────────────────
.venv/
env/
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
*.egg
dist/
build/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
coverage/

# ─────────────────────────────────────────────────────────────────────────────
# Node / Next.js / Vercel / Turbo
# ─────────────────────────────────────────────────────────────────────────────
node_modules/
.next/
.vercel/
.turbo/
*.tsbuildinfo
tsconfig.tsbuildinfo
pnpm-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-store/

# ─────────────────────────────────────────────────────────────────────────────
# App build artifacts (RAG index, BM25 store, manifest)
#   Scoped to backend/ on purpose so a future frontend/public/manifest.json
#   (PWA) or similar wouldn't be silently swallowed.
# ─────────────────────────────────────────────────────────────────────────────
backend/chroma_db/
backend/bm25.pkl
backend/manifest.json

# ─────────────────────────────────────────────────────────────────────────────
# IDE / editors / temp files
# ─────────────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.swn
*~
# sed -i.bak leftovers (scripts/setup.sh uses BSD/GNU-compatible sed -i.bak)
*.bak

# ─────────────────────────────────────────────────────────────────────────────
# OS
# ─────────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─────────────────────────────────────────────────────────────────────────────
# Jupyter
# ─────────────────────────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ─────────────────────────────────────────────────────────────────────────────
# Docker
# ─────────────────────────────────────────────────────────────────────────────
docker-compose.override.yml
